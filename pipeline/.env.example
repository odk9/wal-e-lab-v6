# Copier en .env et remplir

# OpenRouter — obligatoire pour la génération de code
OPENROUTER_API_KEY=sk-or-...

# GitHub — obligatoire pour le deployer
GITHUB_TOKEN=ghp_...

# Pipeline — optionnel (valeurs par défaut)
TARGET_SCORE=80
MAX_ITERATIONS=10

# KB — chemin vers la KB Qdrant (relatif ou absolu)
KB_PATH=../kb/kb_qdrant
